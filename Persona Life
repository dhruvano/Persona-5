<script>
const DAYS=['SUNDAY','MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY'];
const MONS=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const DIFF_PTS=[0,1,2,4,8];
const DIFF_LBLS=['','EASY','NORM','HARD','BOSS'];
const DIFF_CLR=['','#4a9eff','#f5c518','#ff6b35','#e8001a'];
const PT_PER_LVL=10;
const MAX_LVL=20;
const TITLES=['PHANTOM THIEF','SHADOW RUNNER','METAVERSE WALKER','VELVET CHOSEN','WILD CARD','THE LEGEND'];

const STATS=[
  {key:'knowledge', name:'Knowledge',icon:'📚',color:'#4a9eff',ranks:['Oblivious','Aware','Studious','Scholarly','Genius']},
  {key:'creativity',name:'Creativity',icon:'🎨',color:'#e040fb',ranks:['Bumbling','Tinkering','Inventive','Inspired','Virtuoso']},
  {key:'physique',  name:'Physique',  icon:'⚡',color:'#ff6b35',ranks:['Dormant','Stirring','Steady','Athletic','Prime']},
  {key:'social',    name:'Social',    icon:'🎭',color:'#f5c518',ranks:['Isolated','Existent','Charming','Magnetic','Legendary']},
  {key:'guts',      name:'Guts',      icon:'🔥',color:'#e8001a',ranks:['Cowardly','Timid','Composed','Brave','Indomitable']},
];
const BUILDS=[
  {name:'THE SCHOLAR',   desc:'Knowledge dominates — a mind forged sharp.',        req:s=>s.knowledge>Math.max(s.creativity,s.physique,s.social,s.guts)+3},
  {name:'THE CREATOR',   desc:'Creativity runs the show — you make things happen.',req:s=>s.creativity>Math.max(s.knowledge,s.physique,s.social,s.guts)+3},
  {name:'THE WARRIOR',   desc:'Physique first — discipline is your weapon.',        req:s=>s.physique>Math.max(s.knowledge,s.creativity,s.social,s.guts)+3},
  {name:'THE PHANTOM',   desc:'Social mastery — you read people like a book.',      req:s=>s.social>Math.max(s.knowledge,s.creativity,s.physique,s.guts)+3},
  {name:'THE WILDCARD',  desc:'Pure guts — courage and willpower above all.',       req:s=>s.guts>Math.max(s.knowledge,s.creativity,s.physique,s.social)+3},
  {name:'RENAISSANCE',   desc:'All stats elevated — a true phantom thief.',         req:s=>{const v=Object.values(s);return Math.min(...v)>=8&&Math.max(...v)-Math.min(...v)<=4;}},
  {name:'BALANCED',      desc:'Still forging your path — all stats developing.',    req:()=>true},
];

let S={charName:'JOKER',pts:{knowledge:0,creativity:0,physique:0,social:0,guts:0},quests:[],log:[],selStat:'knowledge',selDiff:1,questTab:'active',lastDay:null};
try{const d=localStorage.getItem('ps_v4');if(d)S={...S,...JSON.parse(d)};}catch(e){}
const save=()=>{try{localStorage.setItem('ps_v4',JSON.stringify(S));}catch(e){}};

const getLvl=p=>Math.min(Math.floor(p/PT_PER_LVL)+1,MAX_LVL);
const getLvlPts=p=>p%PT_PER_LVL;
const getRank=k=>{const s=STATS.find(x=>x.key===k);return s.ranks[Math.min(Math.floor((getLvl(S.pts[k])-1)/4),s.ranks.length-1)];};
const getOR=()=>Math.floor(Object.values(S.pts).reduce((a,b)=>a+b,0)/20)+1;
const pad=n=>String(n).padStart(2,'0');
const fmtDT=iso=>{if(!iso)return'—';const d=new Date(iso);return`${d.getDate()} ${MONS[d.getMonth()]} ${d.getFullYear()} · ${pad(d.getHours())}:${pad(d.getMinutes())}`;};

// CLOCK
function tickClocks(){
  const d=new Date();
  const t=`${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
  const dt=`${d.getDate()} ${MONS[d.getMonth()]} — ${DAYS[d.getDay()]}`;
  ['mclock','sc1','sc2','sc3'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=id==='mclock'?t:t;});
  const dc=document.getElementById('mclock-date');if(dc)dc.textContent=dt;
}
setInterval(tickClocks,1000);tickClocks();

// DAY POPUP
function checkDay(){
  const d=new Date();
  const today=`${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`;
  if(S.lastDay!==today){S.lastDay=today;save();setTimeout(()=>showDayPopup(d),700);}
}
function showDayPopup(d){
  const p=document.getElementById('day-popup');
  const dayStr=DAYS[d.getDay()];
  document.getElementById('pop-date').textContent=`${d.getDate()} ${MONS[d.getMonth()]} ${d.getFullYear()}`;
  document.getElementById('pop-day').textContent=dayStr;
  document.getElementById('pop-day').setAttribute('data-t',dayStr);
  document.getElementById('pop-wday').textContent='A NEW DAY BEGINS';
  p.classList.add('show');
  p.onclick=()=>{p.style.transition='opacity .2s';p.style.opacity='0';setTimeout(()=>{p.classList.remove('show');p.style.opacity='';p.style.transition='';},200);};
}
checkDay();

// MENU
document.querySelectorAll('.mtab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.mtab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    const lbl=tab.dataset.lbl,desc=tab.dataset.desc;
    document.getElementById('mbig').textContent=lbl;
    document.getElementById('mcheck').textContent='Check '+lbl.toLowerCase();
    // pennant: split label
    const main=lbl.slice(0,-2),end=lbl.slice(-2);
    document.getElementById('mpennant').innerHTML=`${main}<em>${end}</em>`;
    document.getElementById('mdesc-text').textContent=desc;
    setTimeout(()=>{
      document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
      const sc=document.getElementById(tab.dataset.sc);
      sc.classList.add('active','slide-in');
      setTimeout(()=>sc.classList.remove('slide-in'),240);
      renderScreen(tab.dataset.sc);
    },120);
  });
});

function goMenu(){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById('menu-screen').classList.add('active');}
function renderScreen(id){
  if(id==='status-screen')renderStatus();
  if(id==='quests-screen')renderQuestsScreen();
  if(id==='log-screen')renderLog();
}

// STATUS
function renderStatus(){
  const cn=document.getElementById('cname');cn.value=S.charName;
  cn.oninput=()=>{S.charName=cn.value.toUpperCase()||'JOKER';save();};
  document.getElementById('overall-rank').textContent=`RANK ${getOR()}`;
  document.getElementById('ctitle').textContent=TITLES[Math.min(Math.floor(getOR()/5),TITLES.length-1)];
  // bars
  document.getElementById('sbars').innerHTML=STATS.map(s=>{
    const p=S.pts[s.key],pct=Math.min(getLvlPts(p)/PT_PER_LVL*100,100);
    return`<div class="sbrow"><div class="sbl" style="color:${s.color};">${s.icon} ${s.name}</div><div class="sbt"><div class="sbf" style="width:${pct}%;background:${s.color};--sc:${s.color};"></div></div><div class="sbn" style="color:${s.color};">${getLvl(p)}</div></div>`;
  }).join('');
  // cards
  document.getElementById('sgrid').innerHTML=STATS.map(s=>{
    const p=S.pts[s.key],pct=Math.min(getLvlPts(p)/PT_PER_LVL*100,100);
    return`<div class="scard" style="--sc:${s.color};"><div class="sc-ico">${s.icon}</div><div class="sc-nm">${s.name}</div><div class="sc-lvl">${getLvl(p)}</div><div class="sc-rnk">${getRank(s.key)}</div><div class="sc-nxt">${getLvlPts(p)}/${PT_PER_LVL} pts to next</div><div class="sc-bar"><div class="sc-barf" style="width:${pct}%;"></div></div><div style="font-size:9px;color:#222;margin-top:4px;">Total: ${p} pts</div></div>`;
  }).join('');
  // build
  const lvls=Object.fromEntries(STATS.map(s=>[s.key,getLvl(S.pts[s.key])]));
  const b=BUILDS.find(x=>x.req(lvls))||BUILDS[BUILDS.length-1];
  document.getElementById('bname').textContent=b.name;
  document.getElementById('bdesc').textContent=b.desc;
  requestAnimationFrame(()=>requestAnimationFrame(renderRadar));
}
function renderRadar(){
  const cv=document.getElementById('radar');const ctx=cv.getContext('2d');
  const w=cv.width,h=cv.height,cx=w/2,cy=h/2+2,r=68;
  ctx.clearRect(0,0,w,h);
  const n=5,angles=STATS.map((_,i)=>-Math.PI/2+2*Math.PI*i/n);
  for(let g=1;g<=5;g++){
    ctx.beginPath();
    angles.forEach((a,i)=>{const gr=r*(g/5),x=cx+gr*Math.cos(a),y=cy+gr*Math.sin(a);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
    ctx.closePath();ctx.strokeStyle=g===5?'#222':'#161616';ctx.lineWidth=1;ctx.stroke();
  }
  angles.forEach(a=>{ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+r*Math.cos(a),cy+r*Math.sin(a));ctx.strokeStyle='#161616';ctx.lineWidth=1;ctx.stroke();});
  const vals=STATS.map(s=>Math.min(getLvl(S.pts[s.key])/MAX_LVL,1));
  ctx.beginPath();vals.forEach((v,i)=>{const x=cx+r*v*Math.cos(angles[i]),y=cy+r*v*Math.sin(angles[i]);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.closePath();ctx.fillStyle='rgba(232,0,26,.14)';ctx.fill();ctx.strokeStyle='#e8001a';ctx.lineWidth=2;ctx.stroke();
  STATS.forEach((s,i)=>{
    const v=Math.min(getLvl(S.pts[s.key])/MAX_LVL,1),x=cx+r*v*Math.cos(angles[i]),y=cy+r*v*Math.sin(angles[i]);
    ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fillStyle=s.color;ctx.fill();
    const lx=cx+(r+15)*Math.cos(angles[i]),ly=cy+(r+15)*Math.sin(angles[i]);
    ctx.fillStyle='#4a4a4a';ctx.font='9px Rajdhani,sans-serif';
    ctx.textAlign=lx>cx+5?'left':lx<cx-5?'right':'center';
    ctx.textBaseline=ly>cy+5?'top':ly<cy-5?'bottom':'middle';
    ctx.fillText(s.name.toUpperCase(),lx,ly);
  });
}

// QUESTS
function renderQuestsScreen(){
  // stat tags
  document.getElementById('stags').innerHTML=STATS.map(s=>`<div class="stag ${S.selStat===s.key?'on':''}" style="--tc:${s.color};${S.selStat===s.key?`border-color:${s.color};color:${s.color};`:''}" onclick="setStat('${s.key}')">${s.icon} ${s.name}</div>`).join('');
  renderQList();updatePtsPreview();
  const d=new Date();document.getElementById('qdue').value=`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
}
function setStat(k){S.selStat=k;document.querySelectorAll('.stag').forEach(t=>{const active=t.onclick.toString().includes(`'${k}'`);t.classList.toggle('on',active);const sc=STATS.find(x=>x.key===k);t.style.borderColor=active?sc.color:'';t.style.color=active?sc.color:'';});renderQuestsScreen();}

document.querySelectorAll('.dbtn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');S.selDiff=parseInt(btn.dataset.d);updatePtsPreview();
  });
});
function updatePtsPreview(){
  const p=DIFF_PTS[S.selDiff]||1;
  document.getElementById('pts-val').textContent=p;
  const st=STATS.find(s=>s.key===S.selStat);
  document.getElementById('pts-stat').textContent=st?st.name:'—';
}

document.getElementById('addbtn').addEventListener('click',()=>{
  const name=document.getElementById('qn').value.trim();
  if(!name){showToast('NAME YOUR QUEST FIRST');return;}
  S.quests.push({id:Date.now(),name,desc:document.getElementById('qd').value.trim(),due:document.getElementById('qdue').value,stat:S.selStat,diff:S.selDiff,pts:DIFF_PTS[S.selDiff]||1,completed:false,completedAt:null});
  save();document.getElementById('qn').value='';document.getElementById('qd').value='';
  showToast("QUEST ACCEPTED — LET'S GO");renderQList();
});

document.querySelectorAll('.qtab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.qtab').forEach(t=>t.classList.remove('on'));
    tab.classList.add('on');S.questTab=tab.dataset.tab;renderQList();
  });
});

function dueStatus(str){
  if(!str)return{label:'No due date',cls:''};
  const diff=Math.ceil((new Date(str).setHours(23,59,59)-Date.now())/864e5);
  if(diff<0)return{label:`${Math.abs(diff)}d OVERDUE`,cls:'overdue'};
  if(diff===0)return{label:'DUE TODAY',cls:'urgent'};
  if(diff===1)return{label:'DUE TOMORROW',cls:'urgent'};
  return{label:`In ${diff} days`,cls:''};
}
function renderQList(){
  const list=document.getElementById('qlist');
  const qs=S.quests.filter(q=>S.questTab==='active'?!q.completed:q.completed);
  if(!qs.length){list.innerHTML=`<div class="qempty">NO ${S.questTab.toUpperCase()} QUESTS</div>`;return;}
  const sorted=S.questTab==='active'?[...qs].sort((a,b)=>new Date(a.due)-new Date(b.due)):[...qs].sort((a,b)=>new Date(b.completedAt)-new Date(a.completedAt));
  list.innerHTML=sorted.map(q=>{
    const stat=STATS.find(s=>s.key===q.stat);
    const due=dueStatus(q.due);
    const dc=DIFF_CLR[q.diff]||'#4a9eff',dl=DIFF_LBLS[q.diff]||'EASY';
    const footerLeft=q.completed?`✓ ${fmtDT(q.completedAt)}`:due.label;
    const footerCls=q.completed?'':due.cls;
    return`<div class="qcard ${due.cls==='overdue'&&!q.completed?'overdue':''} ${q.completed?'done':''}">
      <div class="qch">
        <div class="qc-d" style="background:${dc}16;color:${dc};border:1px solid ${dc}2e;">${dl}</div>
        <div class="qc-dot" style="background:${stat.color};color:${stat.color};margin-left:auto;"></div>
        <div class="qc-sn">${stat.icon} ${stat.name}</div>
        <div class="qc-pts" style="color:${dc};">+${q.pts} PT${q.pts!==1?'S':''}</div>
      </div>
      <div class="qcb"><div class="qc-t">${q.name}</div>${q.desc?`<div class="qc-ds">${q.desc}</div>`:''}</div>
      <div class="qcf">
        <div class="qc-due ${footerCls}">${footerLeft}</div>
        ${!q.completed?`<button class="cbtn" onclick="completeQ(${q.id})">✓ COMPLETE</button>`:`<div style="font-size:9px;letter-spacing:2px;color:#1a5a1a;">CLEARED</div>`}
      </div>
    </div>`;
  }).join('');
}
function completeQ(id){
  const q=S.quests.find(x=>x.id===id);if(!q||q.completed)return;
  const prev=getLvl(S.pts[q.stat]);
  S.pts[q.stat]+=q.pts;
  const nxt=getLvl(S.pts[q.stat]);
  q.completed=true;q.completedAt=new Date().toISOString();
  S.log.unshift({text:q.name,stat:q.stat,pts:q.pts,diff:q.diff,ts:Date.now(),completedAt:q.completedAt});
  save();renderQList();
  if(nxt>prev){lvlFlash();showToast(`${STATS.find(s=>s.key===q.stat).name.toUpperCase()} LV.${nxt} — ${getRank(q.stat).toUpperCase()}!`,true);}
  else{showToast(`+${q.pts} ${STATS.find(s=>s.key===q.stat).name.toUpperCase()} PT${q.pts!==1?'S':''}`);}
}

// LOG
function renderLog(){
  const body=document.getElementById('lbody');
  if(!S.log.length){body.innerHTML='<div style="text-align:center;padding:80px;color:#1e1e1e;font-size:9px;letter-spacing:3px;text-transform:uppercase;">No missions yet — complete quests to build your legacy</div>';return;}
  const dn=['','Easy','Normal','Hard','BOSS'];
  body.innerHTML=S.log.map((e,i)=>{
    const st=STATS.find(s=>s.key===e.stat);
    return`<div class="lentry" style="animation-delay:${i*.035}s;">
      <div class="ll" style="background:${st.color};box-shadow:0 0 5px ${st.color};"></div>
      <div class="li">
        <div class="lt">${e.text}</div>
        <div class="lm">${st.icon} ${st.name} · ${dn[e.diff]||''} · ${fmtDT(e.completedAt||new Date(e.ts).toISOString())}</div>
      </div>
      <div class="lp" style="color:${st.color};text-shadow:0 0 7px ${st.color}3a;">+${e.pts}</div>
    </div>`;
  }).join('');
}

// UTILS
function showToast(msg,gold=false){
  const t=document.getElementById('toast');t.textContent=msg;
  t.className='toast'+(gold?' gold':'')+' show';
  clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2600);
}
function lvlFlash(){const f=document.getElementById('lvlflash');f.classList.add('on');setTimeout(()=>f.classList.remove('on'),300);}
</script>
</body>
</html>
