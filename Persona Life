<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PHANTOM STATS</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --red:#e8001a;--red2:#ff1a2e;--red-dim:rgba(232,0,26,0.15);--red-glow:rgba(232,0,26,0.45);
  --cream:#f0ead6;--black:#050505;--dark:#0c0c0c;--mid:#141414;
  --gold:#f5c518;--blue:#2255cc;
}
html,body{height:100%;overflow:hidden;}
body{background:var(--black);color:#fff;font-family:'Rajdhani',sans-serif;cursor:default;position:relative;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.07) 3px,rgba(0,0,0,0.07) 4px);pointer-events:none;z-index:9000;}

/* ══ SCREENS ══ */
.screen{display:none;width:100vw;height:100vh;position:relative;overflow:hidden;}
.screen.active{display:flex;flex-direction:column;}
.screen.slide-in{animation:slideIn .22s cubic-bezier(.4,0,.2,1) both;}
@keyframes slideIn{from{transform:translateX(30px);opacity:0;}to{transform:none;opacity:1;}}

/* ══ DAY POPUP ══ */
#day-popup{position:fixed;inset:0;z-index:9900;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,0.88);}
#day-popup.show{display:flex;}
.dpi{position:relative;text-align:center;animation:popSlam .4s cubic-bezier(.2,0,0,1.4) .1s both;}
@keyframes popSlam{from{transform:scale(.5) rotate(-6deg);opacity:0;}to{transform:none;opacity:1;}}
.dpi-sub{font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:6px;color:var(--red);margin-bottom:6px;text-shadow:0 0 16px var(--red-glow);}
.dpi-day{font-family:'Bebas Neue',sans-serif;font-size:80px;letter-spacing:6px;color:var(--cream);line-height:1;position:relative;}
.dpi-day::before{content:attr(data-t);position:absolute;inset:0;color:var(--red);clip-path:polygon(0 0,100% 0,100% 38%,0 38%);transform:translateX(4px);opacity:.6;}
.dpi-wday{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:10px;color:#555;margin-top:4px;}
.dpi-bar{width:0;height:3px;background:var(--red);margin:18px auto 0;animation:barG .6s ease .5s forwards;box-shadow:0 0 10px var(--red-glow);}
@keyframes barG{to{width:280px;}}
.dpi-hint{font-size:12px;letter-spacing:3px;color:#333;margin-top:14px;text-transform:uppercase;animation:fadeH .5s ease 1s both;}
@keyframes fadeH{from{opacity:0;}to{opacity:1;}}

/* ══ MENU ══ */
#menu-screen{background:var(--black);}
.mbg{position:absolute;inset:0;z-index:0;overflow:hidden;}
.mbg::before{content:'';position:absolute;inset:-200%;background:repeating-linear-gradient(-50deg,transparent,transparent 36px,rgba(232,0,26,.042) 36px,rgba(232,0,26,.042) 38px);animation:bgS 22s linear infinite;}
@keyframes bgS{from{transform:none;}to{transform:translateX(76px) translateY(76px);}}
.mbg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 55% 60% at 78% 50%,rgba(232,0,26,.055) 0%,transparent 70%);}

/* red diagonal split — the signature P5 look */
.mslash{position:absolute;inset:0;z-index:1;pointer-events:none;}
.mslash::before{content:'';position:absolute;top:0;bottom:0;right:0;width:56%;background:rgba(10,10,10,.5);clip-path:polygon(7% 0,100% 0,100% 100%,0 100%);}
.mslash::after{content:'';position:absolute;top:0;bottom:0;left:44%;width:3px;background:linear-gradient(180deg,transparent 0%,var(--red) 25%,var(--red) 75%,transparent 100%);opacity:.55;}

/* spinning star */
.mstar{position:absolute;z-index:1;right:-100px;top:50%;transform:translateY(-50%);width:640px;height:640px;pointer-events:none;animation:starS 44s linear infinite;opacity:.038;}
@keyframes starS{from{transform:translateY(-50%) rotate(0);}to{transform:translateY(-50%) rotate(360deg);}}

/* top bar */
.mtop{position:relative;z-index:5;display:flex;justify-content:space-between;align-items:center;padding:0 28px;height:52px;background:rgba(5,5,5,.98);border-bottom:2px solid var(--red);box-shadow:0 2px 20px rgba(232,0,26,.18);}
.mlogo{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:5px;color:var(--cream);}
.mlogo em{color:var(--red);font-style:normal;text-shadow:0 0 14px var(--red-glow);}
.mclock-wrap{display:flex;flex-direction:column;align-items:flex-end;gap:1px;}
.mclock{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:3px;color:var(--cream);}
.mclock-date{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:3px;color:#555;}

/* menu body */
.mbody{position:relative;z-index:3;flex:1;display:flex;align-items:stretch;}

/* LEFT tabs — P5 stacked style */
.mtabs{display:flex;flex-direction:column;justify-content:center;padding:0 0 0 36px;gap:3px;min-width:260px;z-index:4;}
.mtab{
  position:relative;padding:13px 40px 13px 16px;cursor:pointer;
  clip-path:polygon(0 0,calc(100% - 18px) 0,100% 50%,calc(100% - 18px) 100%,0 100%);
  background:rgba(16,16,16,.97);font-family:'Bebas Neue',sans-serif;
  font-size:26px;letter-spacing:4px;color:#555;user-select:none;
  border-left:3px solid transparent;transition:color .12s,background .12s;
}
.mtab:hover{background:rgba(24,24,24,.97);color:#888;border-left-color:rgba(232,0,26,.25);}
.mtab.active{background:var(--red);color:#fff;border-left-color:var(--gold);box-shadow:6px 0 28px rgba(232,0,26,.45);text-shadow:0 0 14px rgba(255,255,255,.2);animation:tabPop .2s cubic-bezier(.2,0,0,1.5) both;}
@keyframes tabPop{from{transform:scaleX(.95);}to{transform:none;}}
.mtab.active::before{content:'▶';position:absolute;left:-17px;top:50%;transform:translateY(-50%);color:var(--gold);font-size:13px;text-shadow:0 0 8px var(--gold);}

/* RIGHT side — pennant + desc */
.mright{flex:1;display:flex;flex-direction:column;justify-content:center;padding:0 44px;position:relative;}
.mbig{font-family:'Bebas Neue',sans-serif;font-size:90px;letter-spacing:6px;color:rgba(232,0,26,.042);line-height:1;pointer-events:none;position:absolute;top:50%;left:44px;transform:translateY(-54%);white-space:nowrap;}

/* The P5 pennant banner */
.mpennant{
  position:relative;z-index:2;background:var(--cream);color:var(--black);
  font-family:'Bebas Neue',sans-serif;font-size:50px;letter-spacing:4px;
  padding:10px 36px 10px 18px;
  clip-path:polygon(0 0,calc(100% - 26px) 0,100% 50%,calc(100% - 26px) 100%,0 100%);
  display:inline-block;align-self:flex-start;margin-bottom:14px;
  box-shadow:4px 4px 0 var(--red),8px 8px 0 rgba(232,0,26,.2);
  animation:pennantIn .28s cubic-bezier(.4,0,.2,1) both;
}
@keyframes pennantIn{from{opacity:0;transform:translateX(-18px);}to{opacity:1;transform:none;}}
.mpennant em{font-style:normal;color:var(--red);}

/* check quests label (like P5) */
.mcheck{
  position:relative;z-index:2;font-size:11px;letter-spacing:3px;color:var(--red);
  text-transform:uppercase;margin-bottom:10px;animation:pennantIn .28s ease .05s both;
}
.mcheck::before{content:'— ';color:#444;}

.mdesc{
  position:relative;z-index:2;background:rgba(8,8,8,.97);
  border:1px solid rgba(232,0,26,.18);padding:16px 20px;max-width:360px;
  animation:descIn .28s ease .1s both;
}
@keyframes descIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:none;}}
.mdesc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--red);box-shadow:0 0 8px var(--red-glow);}
.mdesc-label{font-size:10px;letter-spacing:3px;color:var(--red);text-transform:uppercase;margin-bottom:6px;}
.mdesc-text{font-size:13px;color:#666;line-height:1.65;}

/* Joker */
.mjoker{position:absolute;bottom:0;right:36px;width:230px;pointer-events:none;z-index:4;animation:jFloat 3s ease-in-out infinite;filter:drop-shadow(0 0 22px rgba(232,0,26,.28)) drop-shadow(0 0 4px rgba(232,0,26,.12));}
@keyframes jFloat{0%,100%{transform:none;}50%{transform:translateY(-11px);}}

/* ══ SHARED SCREEN HEADER ══ */
.sh{display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:52px;flex-shrink:0;background:rgba(5,5,5,.98);border-bottom:2px solid var(--red);position:relative;z-index:10;}
.sh::after{content:'';position:absolute;bottom:-2px;left:0;width:80px;height:2px;background:var(--gold);box-shadow:0 0 10px var(--gold);}
.sh-title{font-family:'Bebas Neue',sans-serif;font-size:23px;letter-spacing:6px;color:var(--cream);}
.sh-title span{color:var(--red);text-shadow:0 0 10px var(--red-glow);}
.sh-r{display:flex;align-items:center;gap:14px;}
.sh-clock{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:2px;color:#383838;}
.back-btn{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:3px;color:#444;cursor:pointer;padding:5px 15px;border:1px solid #1e1e1e;background:transparent;transition:all .15s;clip-path:polygon(5px 0,100% 0,calc(100% - 5px) 100%,0 100%);}
.back-btn:hover{color:var(--cream);border-color:var(--red);background:rgba(232,0,26,.07);box-shadow:0 0 10px var(--red-dim);}

/* ══ STATUS ══ */
#status-screen{background:var(--black);}
.sbody{display:grid;grid-template-columns:295px 1fr;height:calc(100vh - 52px);overflow:hidden;}
.cpanel{background:var(--dark);border-right:1px solid rgba(232,0,26,.09);padding:18px 16px;display:flex;flex-direction:column;gap:14px;overflow-y:auto;}
.ccard{background:var(--mid);border:1px solid rgba(232,0,26,.16);overflow:hidden;box-shadow:0 0 18px rgba(232,0,26,.04);}
.cct{background:linear-gradient(100deg,var(--red) 0%,#7a000e 100%);padding:8px 13px;display:flex;justify-content:space-between;align-items:center;position:relative;overflow:hidden;}
.cct::after{content:'';position:absolute;right:-8px;top:0;bottom:0;width:32px;background:rgba(255,255,255,.06);transform:skewX(-14deg);}
.cct-c{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:3px;color:rgba(255,255,255,.5);}
.cct-r{font-family:'Bebas Neue',sans-serif;font-size:16px;color:#fff;text-shadow:0 0 8px rgba(255,255,255,.28);}
.cart{height:148px;display:flex;align-items:center;justify-content:center;background:radial-gradient(ellipse at 50% 90%,rgba(232,0,26,.1) 0%,#080808 65%);position:relative;overflow:hidden;}
.cart::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(-45deg,transparent,transparent 16px,rgba(232,0,26,.014) 16px,rgba(232,0,26,.014) 17px);}
.cart::after{content:'';position:absolute;bottom:0;left:0;right:0;height:38px;background:linear-gradient(0deg,var(--mid),transparent);}
.cnb{padding:9px 13px;border-top:1px solid rgba(232,0,26,.07);}
.cname{background:transparent;border:none;border-bottom:1px solid #1e1e1e;color:var(--cream);font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:3px;width:100%;outline:none;cursor:text;transition:border-color .15s;}
.cname:focus{border-bottom-color:var(--red);}
.ctitle{font-size:9px;letter-spacing:3px;color:var(--red);text-transform:uppercase;margin-top:3px;text-shadow:0 0 6px var(--red-dim);}
.sbars{display:flex;flex-direction:column;gap:8px;}
.sbrow{display:flex;align-items:center;gap:7px;}
.sbl{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#3a3a3a;min-width:82px;}
.sbt{flex:1;height:4px;background:#0e0e0e;border:1px solid #1c1c1c;position:relative;}
.sbf{height:100%;transition:width .7s cubic-bezier(.4,0,.2,1);}
.sbf::after{content:'';position:absolute;right:0;top:-4px;width:2px;height:12px;background:inherit;box-shadow:0 0 8px var(--sc,#fff);}
.sbn{font-family:'Bebas Neue',sans-serif;font-size:14px;min-width:22px;text-align:right;}
.radarw{display:flex;flex-direction:column;align-items:center;gap:4px;}
.radarlbl{font-size:8px;letter-spacing:3px;color:rgba(232,0,26,.4);text-transform:uppercase;}
.spanel{padding:18px;overflow-y:auto;display:flex;flex-direction:column;gap:16px;}
.bbanner{background:var(--mid);border:1px solid rgba(232,0,26,.16);padding:12px 16px;position:relative;overflow:hidden;}
.bbanner::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--red);box-shadow:0 0 9px var(--red-glow);}
.bbanner::after{content:'';position:absolute;bottom:0;right:0;width:0;height:0;border-style:solid;border-width:0 0 22px 22px;border-color:transparent transparent rgba(232,0,26,.1) transparent;}
.bbl{font-size:9px;letter-spacing:3px;color:#333;text-transform:uppercase;margin-left:9px;}
.bbn{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:3px;color:var(--gold);margin-left:9px;text-shadow:0 0 9px rgba(245,197,24,.18);}
.bbd{font-size:11px;color:#3a3a3a;margin-top:2px;margin-left:9px;}
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.scard{background:var(--mid);border:1px solid #181818;padding:13px;position:relative;overflow:hidden;transition:all .15s;}
.scard:hover{border-color:var(--sc);box-shadow:0 0 14px rgba(0,0,0,.4);}
.scard::before{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;background:var(--sc);box-shadow:0 0 5px var(--sc);}
.scard::after{content:'';position:absolute;top:0;right:0;width:0;height:0;border-style:solid;border-width:0 14px 14px 0;border-color:transparent var(--sc) transparent transparent;opacity:.2;}
.sc-ico{font-size:20px;margin-bottom:4px;}
.sc-nm{font-size:9px;letter-spacing:3px;color:#3a3a3a;text-transform:uppercase;margin-bottom:2px;}
.sc-lvl{font-family:'Bebas Neue',sans-serif;font-size:40px;color:#fff;line-height:1;}
.sc-rnk{font-size:10px;letter-spacing:2px;color:var(--sc);text-transform:uppercase;margin-top:2px;}
.sc-nxt{font-size:10px;color:#282828;margin-top:5px;}
.sc-bar{height:2px;background:#0e0e0e;margin-top:4px;overflow:hidden;}
.sc-barf{height:100%;background:var(--sc);transition:width .5s;box-shadow:0 0 3px var(--sc);}

/* ══ QUESTS ══ */
#quests-screen{background:var(--black);}
.qbody{display:grid;grid-template-columns:350px 1fr;height:calc(100vh - 52px);overflow:hidden;}
.qform{background:var(--dark);border-right:1px solid rgba(232,0,26,.09);padding:18px;display:flex;flex-direction:column;gap:11px;overflow-y:auto;}
.qft{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:4px;color:var(--red);border-bottom:1px solid rgba(232,0,26,.14);padding-bottom:6px;text-shadow:0 0 7px var(--red-dim);}
.pf{display:flex;flex-direction:column;gap:4px;}
.pfl{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#333;}
.pi{background:rgba(7,7,7,.97);border:1px solid #1c1c1c;color:#ccc;font-family:'Rajdhani',sans-serif;font-size:14px;padding:7px 10px;outline:none;width:100%;transition:all .15s;}
.pi:focus{border-color:var(--red);box-shadow:0 0 9px var(--red-dim);}
.pi::placeholder{color:#1e1e1e;}
textarea.pi{resize:vertical;min-height:52px;}
.stags{display:flex;flex-wrap:wrap;gap:4px;}
.stag{padding:4px 9px;font-size:9px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border:1px solid #1c1c1c;background:transparent;color:#333;transition:all .15s;font-family:'Rajdhani',sans-serif;}
.stag:hover{border-color:#333;color:#666;}
.stag.on{color:#fff;border-color:var(--tc);text-shadow:0 0 5px var(--tc);}
.ptsprev{background:rgba(232,0,26,.04);border:1px solid rgba(232,0,26,.14);padding:9px 12px;display:flex;align-items:center;justify-content:space-between;}
.ptsprev-l{font-size:9px;letter-spacing:3px;color:#444;text-transform:uppercase;}
.ptsprev-s{font-size:9px;letter-spacing:2px;color:#333;text-transform:uppercase;margin-top:2px;}
.ptsprev-v{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--gold);text-shadow:0 0 9px rgba(245,197,24,.25);}
.dbtns{display:flex;gap:4px;}
.dbtn{flex:1;padding:8px 4px;font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;cursor:pointer;border:1px solid #1c1c1c;background:transparent;color:#333;transition:all .15s;text-align:center;}
.dbtn:hover{border-color:#333;color:#666;}
.dbtn.on{border-color:var(--dc);color:var(--dc);background:rgba(0,0,0,.4);text-shadow:0 0 7px var(--dc);}
.addbtn{width:100%;background:var(--red);border:none;color:#fff;font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:5px;padding:12px;cursor:pointer;clip-path:polygon(9px 0,100% 0,calc(100% - 9px) 100%,0 100%);transition:all .15s;position:relative;overflow:hidden;box-shadow:0 4px 18px rgba(232,0,26,.32);}
.addbtn::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.09),transparent);transform:translateX(-100%);transition:transform .4s;}
.addbtn:hover{background:var(--red2);box-shadow:0 4px 28px rgba(232,0,26,.52);}
.addbtn:hover::before{transform:translateX(100%);}
.qlpanel{padding:16px 18px;overflow-y:auto;display:flex;flex-direction:column;gap:9px;}
.qtabs{display:flex;border-bottom:1px solid rgba(232,0,26,.1);margin-bottom:13px;}
.qtab{font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:3px;padding:8px 18px;cursor:pointer;color:#333;border-bottom:2px solid transparent;transition:all .15s;}
.qtab:hover{color:#666;}
.qtab.on{color:var(--cream);border-bottom-color:var(--red);}
.qcard{background:var(--mid);border:1px solid #181818;overflow:hidden;transition:all .15s;animation:cardIn .2s ease both;}
@keyframes cardIn{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:none;}}
.qcard:hover{border-color:#222;}
.qcard.overdue{border-left:3px solid var(--red);}
.qcard.done{opacity:.42;border-left:3px solid #1a3a1a;}
.qch{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid #101010;background:rgba(0,0,0,.22);}
.qc-d{font-family:'Bebas Neue',sans-serif;font-size:9px;letter-spacing:2px;padding:2px 8px;clip-path:polygon(3px 0,100% 0,calc(100% - 3px) 100%,0 100%);}
.qc-dot{width:5px;height:5px;border-radius:50%;margin-left:auto;box-shadow:0 0 4px currentColor;}
.qc-sn{font-size:9px;letter-spacing:2px;color:#333;text-transform:uppercase;}
.qc-pts{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;padding:1px 8px;background:rgba(0,0,0,.4);border:1px solid #181818;}
.qcb{padding:9px 12px;}
.qc-t{font-size:14px;font-weight:600;color:#bbb;margin-bottom:2px;}
.qc-ds{font-size:12px;color:#333;line-height:1.5;}
.qcf{display:flex;align-items:center;justify-content:space-between;padding:7px 12px;background:rgba(0,0,0,.16);border-top:1px solid #101010;}
.qc-due{font-size:9px;letter-spacing:2px;color:#2e2e2e;text-transform:uppercase;}
.qc-due.urgent{color:#ff6b35;}
.qc-due.overdue{color:var(--red);}
.cbtn{font-family:'Bebas Neue',sans-serif;font-size:9px;letter-spacing:3px;padding:4px 12px;border:1px solid #1a3a1a;background:transparent;color:#1a5a1a;cursor:pointer;transition:all .15s;clip-path:polygon(3px 0,100% 0,calc(100% - 3px) 100%,0 100%);}
.cbtn:hover{background:rgba(26,90,26,.15);color:#3a9a3a;border-color:#2a7a2a;}
.qempty{text-align:center;padding:50px 20px;color:#1e1e1e;font-size:9px;letter-spacing:3px;text-transform:uppercase;}

/* ══ LOG ══ */
#log-screen{background:var(--black);}
.lbody{padding:18px 30px;flex:1;overflow-y:auto;height:calc(100vh - 52px);}
.lentry{display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid #0d0d0d;transition:background .12s;animation:cardIn .2s ease both;}
.lentry:hover{background:rgba(232,0,26,.012);}
.ll{width:2px;flex-shrink:0;align-self:stretch;min-height:36px;}
.li{flex:1;}
.lt{font-size:14px;font-weight:600;color:#b0b0b0;}
.lm{font-size:9px;color:#2e2e2e;margin-top:3px;letter-spacing:2px;text-transform:uppercase;}
.lp{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;}

/* ══ TOAST + FLASH ══ */
.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--red);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:4px;padding:11px 28px;clip-path:polygon(10px 0,100% 0,calc(100% - 10px) 100%,0 100%);transition:transform .3s cubic-bezier(.4,0,.2,1);z-index:9800;white-space:nowrap;box-shadow:0 4px 28px rgba(232,0,26,.48);}
.toast.show{transform:translateX(-50%) translateY(0);}
.toast.gold{background:var(--gold);color:var(--black);box-shadow:0 4px 28px rgba(245,197,24,.48);}
.lvlflash{position:fixed;inset:0;pointer-events:none;opacity:0;z-index:9700;transition:opacity .1s;background:radial-gradient(ellipse at 50% 50%,rgba(232,0,26,.22) 0%,transparent 70%);}
.lvlflash.on{opacity:1;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:#080808;}
::-webkit-scrollbar-thumb{background:rgba(232,0,26,.22);}
::-webkit-scrollbar-thumb:hover{background:rgba(232,0,26,.42);}
</style>
